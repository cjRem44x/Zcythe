# Tests — @test blocks in Zcythe, run with `zcy test`
# Mirrors Zig's built-in test system.

@test "basic arithmetic" {
    x := 2 + 2
    @assert_eq(x, 4)
}

@test "string equality" {
    s :: "hello"
    @assert_str(s, "hello")
}

@test "boolean assert" {
    a := 10
    b := 20
    @assert(a < b)
}

@test "multiple assertions" {
    n := 100
    @assert(n > 0)
    @assert(n < 200)
    @assert_eq(n, 100)
}

# Run all @test blocks:
#   zcy test
#
# Output:
#   1/4 main.test.basic arithmetic...OK
#   2/4 main.test.string equality...OK
#   3/4 main.test.boolean assert...OK
#   4/4 main.test.multiple assertions...OK
#   All 4 tests passed.
