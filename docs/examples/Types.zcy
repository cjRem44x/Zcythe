@main {
    x := 32 # this is a mutable implicit type

    y : str = "hello world" # this is a mutable explicit type

    PI :: 3.145 # this is a immutable implicit type

    FOO :str: "Bar" # this is a immutbale explicit type

    Grade : u8 = 'B'
}

TYPES:

-----------  INTS
i8 | u8 
i16 | u16
i32 | u32 
i64 | u64
i128 | u128
----------- FLOATS
f16 
f32 
f64
f128
----------- 
str = []const u8
